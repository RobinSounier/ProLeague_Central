# ============================================
# Configuration Docker Compose - EXEMPLE
# ============================================
# 
# 📋 INSTRUCTIONS :
# 1. Copiez ce fichier en .env : cp .env.example .env
# 2. Modifiez les valeurs selon vos besoins
# 3. Le fichier .env est automatiquement ignoré par Git (.gitignore)
# 4. Ne commitez JAMAIS le fichier .env dans Git !
#
# ============================================

# --------------------------------------------
# Configuration Apache / PHP
# --------------------------------------------
# Port Apache (changez si le port 80 est déjà utilisé)
# Exemples : 8000, 8080, 3000
APACHE_PORT=8003
PHP_ERROR_REPORTING=E_ALL
PHP_DISPLAY_ERRORS=On

# --------------------------------------------
# Configuration MariaDB
# --------------------------------------------
MARIADB_PORT=3312

# Mots de passe - ⚠️ CHANGEZ CES VALEURS !
MYSQL_ROOT_PASSWORD=admin
MYSQL_DATABASE=ProLeague_Central
MYSQL_USER=admin
MYSQL_PASSWORD=admin

# Autoriser les connexions root depuis n'importe quel host (développement uniquement)
MYSQL_ROOT_HOST=%

# --------------------------------------------
# Noms des containers Docker (pour aliases.sh)
# --------------------------------------------
APACHE_CONTAINER=apache_ProLeague_Central
MARIADB_CONTAINER=mariadb_ProLeague_Central

# --------------------------------------------
# Permissions utilisateur (pour éviter les problèmes de permissions)
# --------------------------------------------
# Ces valeurs correspondent à votre utilisateur système
# Les fichiers créés dans ./www auront les mêmes permissions que votre utilisateur
# Pour trouver votre UID/GID : id -u && id -g
HOST_UID=1000
HOST_GID=1000
HOST_USER=www-data
