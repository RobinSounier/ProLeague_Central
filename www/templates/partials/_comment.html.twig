{# Affichage récursif d'un commentaire et de ses réponses #}
<div class="card p-6 {{ level > 0 ? 'ml-8 border-l-4 border-indigo-200' : '' }}">
    <div class="flex items-start space-x-4">
        <div class="flex-1">
            {# En-tête du commentaire #}
            <div class="flex items-center space-x-2 mb-2">
                <span class="font-semibold text-gray-900">{{ comment.author.pseudo ?? 'Utilisateur supprimé' }}</span>
                <span class="text-sm text-gray-500">{{ comment.createdAt|date('d/m/Y à H:i') }}</span>
            </div>

            {# Contenu du commentaire #}
            <p class="text-gray-700 whitespace-pre-line mb-4">{{ comment.content }}</p>

            {# Bouton répondre #}
            {% if app.user and level < 3 %}
                <button type="button"
                        class="text-sm text-indigo-600 hover:text-indigo-800 font-medium"
                        onclick="document.getElementById('reply-form-{{ comment.id }}').classList.toggle('hidden')">
                    Répondre
                </button>

                {# Formulaire de réponse (caché par défaut) #}
                <div id="reply-form-{{ comment.id }}" class="hidden mt-4">
                    <form action="{{ path('app_comment_create', {id: tournament.id}) }}" method="POST" class="space-y-3">
                        <input type="hidden" name="comment[_token]"
                               value="{{ csrf_token('submit_tournament_' ~ tournament.id) }}">
                        <input type="hidden" name="comment[parentComment]" value="{{ comment.id }}">
                        <textarea name="comment[content]"
                                  rows="3"
                                  placeholder="Écrivez votre réponse..."
                                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors outline-none resize-none"
                                  required></textarea>
                        <button type="submit" class="btn-primary flex items-center space-x-2">
                            <svg class="icon-with-text" fill="none" stroke="currentColor" viewbox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                            </svg>
                            <span>Répondre</span>
                        </button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>

    {# Réponses récursives #}
    {% if comment.comments|length > 0 %}
        <div class="mt-4 space-y-4">
            {% for reply in comment.comments %}
                {% include "partials/_comment.html.twig" with {
                    'comment': reply,
                    'level': level + 1,
                    'tournament': tournament
                } %}
            {% endfor %}
        </div>
    {% endif %}
</div>
