{% extends 'base.html.twig' %}

{% block title %}Pro League Central - Accueil
{% endblock %}

{% block body %}
	<section class="gradient-hero section">
		<div class="container-main">
			<div class="text-center">

				<h1 class="text-5xl md:text-6xl text-gray-900 mb-6 uppercase font-black tracking-tight">Dominez l'Arène E-Sport</h1>
				<p class="text-xl md:text-2xl text-gray-600 mb-6 max-w-3xl mx-auto">
					La plateforme ultime pour la compétition amateur et semi-pro. Créez votre team, inscrivez-vous aux tournois et gravissez le ladder vers la gloire.
				</p>

				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					{% if not app.user %}
						<a href="#" class="btn-primary-xl inline-flex items-center justify-center space-x-2 ">
							<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewbox="0 0 24 24"><path fill="currentColor" d="M15 14c-2.67 0-8 1.33-8 4v2h16v-2c0-2.67-5.33-4-8-4m-9-4V7H4v3H1v2h3v3h2v-3h3v-2m6 2a4 4 0 0 0 4-4a4 4 0 0 0-4-4a4 4 0 0 0-4 4a4 4 0 0 0 4 4"/></svg>
							<span>Créer un compte et rejoins la compétition !</span>
						</a>
						<a href="#" class="btn-secondary-lg inline-flex items-center justify-center space-x-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewbox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.618 21.25c0-3.602-4.016-6.53-7.618-6.53s-7.618 2.928-7.618 6.53M12 11.456a4.353 4.353 0 1 0 0-8.706a4.353 4.353 0 0 0 0 8.706"/></svg>
							<span>Deja inscrit ? connecte toi
							</span>
						</a>
					{% else %}

						<a href="#" class="btn-primary-xl inline-flex items-center justify-center space-x-2 ">
							<svg class="icon-with-text" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewbox="0 0 24 24"><path fill="currentColor" d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94A5.01 5.01 0 0 0 11 15.9V19H7v2h10v-2h-4v-3.1c2.24-.23 4.15-1.85 4.61-4.01A5.02 5.02 0 0 0 19 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/></svg>
							<span>Trouver un tournoi</span>
						</a>
						<a href="{{ path('app_team_index') }}" class="btn-secondary-lg inline-flex items-center justify-center space-x-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewbox="0 0 24 24"><path fill="currentColor" d="M12 10a4 4 0 1 0 0-8a4 4 0 0 0 0 8m-6.5 3a2.5 2.5 0 1 0 0-5a2.5 2.5 0 0 0 0 5M21 10.5a2.5 2.5 0 1 1-5 0a2.5 2.5 0 0 1 5 0m-9 .5a5 5 0 0 1 5 5v6H7v-6a5 5 0 0 1 5-5m-7 5c0-.693.1-1.362.288-1.994l-.17.014A3.5 3.5 0 0 0 2 17.5V22h3zm17 6v-4.5a3.5 3.5 0 0 0-3.288-3.494c.187.632.288 1.301.288 1.994v6z"/></svg>
							<span>Trouver une equipe</span>
						</a>

					{% endif %}
				</div>
			</div>
		</div>
	</section>

	<section id="fonctionnalites" class="section bg-white">
		<div class="container-main">
			<div class="text-center mb-16">
				<h2 class="text-4xl text-gray-900 mb-4 font-bold">Le fonctionnement de Pro League Central
				</h2>
				<p class="text-xl text-gray-600 max-w-2xl mx-auto">
					Tout ce dont vous avez besoin pour gérer votre carrière e-sportive.
				</p>
			</div>

			<div class="grid md:grid-cols-3 gap-8">
				<div class="gradient-card-primary rounded-xl p-8 shadow-lg hover:shadow-xl transition-shadow ">
					<div class="w-16 h-16 rounded-full flex items-center justify-center mb-6 bg-primary">
						<svg class="icon-lg text-white" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewbox="0 0 24 24"><path fill="currentColor" d="M12 10a4 4 0 1 0 0-8a4 4 0 0 0 0 8m-6.5 3a2.5 2.5 0 1 0 0-5a2.5 2.5 0 0 0 0 5M21 10.5a2.5 2.5 0 1 1-5 0a2.5 2.5 0 0 1 5 0m-9 .5a5 5 0 0 1 5 5v6H7v-6a5 5 0 0 1 5-5m-7 5c0-.693.1-1.362.288-1.994l-.17.014A3.5 3.5 0 0 0 2 17.5V22h3zm17 6v-4.5a3.5 3.5 0 0 0-3.288-3.494c.187.632.288 1.301.288 1.994v6z"/></svg>
					</div>
					<h3 class="text-2xl text-gray-900 mb-4 font-bold">Inscrivez votre Team</h3>
					<p class="text-gray-700 leading-relaxed">
						Rejoignez des tournois quotidiens sur vos jeux favoris. Gérez votre roster, validez votre présence et préparez-vous au match.
					</p>
				</div>
				<div class="gradient-card-accent rounded-xl p-8 shadow-lg hover:shadow-xl transition-shadow ">
					<div class="w-16 h-16 rounded-full flex items-center justify-center mb-6 bg-blue-600">
						<svg class="icon-lg text-white" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewbox="0 0 24 24"><path fill="currentColor" d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05c1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
					</div>
					<h3 class="text-2xl text-gray-900 mb-4 font-bold">Recrutez des talents</h3>
					<p class="text-gray-700 leading-relaxed">
						Il vous manque un joueur ? Utilisez notre système de recrutement pour compléter votre escouade ou trouver une équipe à rejoindre.
					</p>
				</div>
				<div class="gradient-card-accent-alt rounded-xl p-8 shadow-lg hover:shadow-xl transition-shadow ">
					<div class="w-16 h-16 rounded-full flex items-center justify-center mb-6 bg-purple-600">
						<svg class="icon-lg text-white" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewbox="0 0 24 24"><path fill="currentColor" d="M16 6l2.29 2.29l-4.88 4.88l-4-4L2 16.59L3.41 18l6-6l4 4l6.3-6.29L22 12V6z"/></svg>
					</div>
					<h3 class="text-2xl text-gray-900 mb-4 font-bold">Grimpez le Ladder</h3>
					<p class="text-gray-700 leading-relaxed">
						Chaque victoire compte. Gagnez des points ELO, débloquez des badges et tentez de remporter le Cashprize mensuel.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section bg-main">
		<div class="container-main">

			<div class="text-center mb-16">
				<h2 class="text-4xl text-gray-900 mb-4 font-bold">Choisissez votre Champ de Bataille</h2>
				<p class="text-xl text-gray-600 max-w-2xl mx-auto">
					Des tournois disponibles sur tous les styles de jeu.
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
				<div class="card-hover p-6 text-center border border-gray-100 rounded-lg bg-white shadow-sm">
					<div class="text-5xl mb-4 ">🪖​</div>
					<h3 class="text-xl text-gray-900 font-bold mb-2">FPS Tactique</h3>
					<p class="text-gray-600">Valorant, CS2, R6 Siege</p>
				</div>
				<div class="card-hover p-6 text-center border border-gray-100 rounded-lg bg-white shadow-sm">
					<div class="text-5xl mb-4 ">⚔️</div>
					<h3 class="text-xl text-gray-900 font-bold mb-2">MOBA</h3>
					<p class="text-gray-600">League of Legends, Dota 2</p>
				</div>
				<div class="card-hover p-6 text-center border border-gray-100 rounded-lg bg-white shadow-sm">
					<div class="text-5xl mb-4 ">🪂</div>
					<h3 class="text-xl text-gray-900 font-bold mb-2">Battle Royale</h3>
					<p class="text-gray-600">Fortnite, Warzone, Apex</p>
				</div>
				<div class="card-hover p-6 text-center border border-gray-100 rounded-lg bg-white shadow-sm">
					<div class="text-5xl mb-4 ">⚽</div>
					<h3 class="text-xl text-gray-900 font-bold mb-2">Sport & Combat</h3>
					<p class="text-gray-600">FC 26, Rocket League, SF6</p>
				</div>
			</div>
		</div>
	</section>
{% endblock %}
