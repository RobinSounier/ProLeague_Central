{% extends 'admin/base.html.twig' %}

{% block title %}Utilisateurs - Administration
{% endblock %}

{% block admin_content %}
    <div class="mb-8">
        <h1 class="text-4xl text-gray-900 mb-2">Gestion des utilisateurs</h1>
        <p class="text-gray-600">Gérez les utilisateurs de Pro League Central</p>
    </div>

    <!-- Recherche et filtres -->
    <div class="card-padded mb-6">
        <form method="get" class="flex flex-col md:flex-row gap-4">
            <input type="text" name="search" value="{{ search }}" placeholder="Rechercher par pseudo ou email..." class="form-input">
            <select name="filter" class="form-select">
                <option value="all" {{ filter == 'all' ? 'selected' : '' }}>Tous</option>
                <option value="active" {{ filter == 'active' ? 'selected' : '' }}>Actifs</option>
                <option value="inactive" {{ filter == 'inactive' ? 'selected' : '' }}>Inactifs</option>
                <option value="admins" {{ filter == 'admins' ? 'selected' : '' }}>Administrateurs</option>
            </select>
            <button type="submit" class="btn-primary">Rechercher</button>
            <a href="{{ path('app_admin_user') }}" class="btn-secondary">Réinitialiser</a>
        </form>
    </div>

    <!-- Compteur de résultats -->
    <div class="mb-4">
        <p class="text-sm text-gray-600">
            <strong>{{ pagination.getTotalItemCount }}</strong> utilisateur(s) trouvé(s)
        </p>
    </div>

    <!-- Liste des utilisateurs -->
    <div class="card-padded min-w-full">
        {% if pagination.getTotalItemCount > 0 %}
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Utilisateur</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rôle</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Statut</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Inscription</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                    {% for user in pagination %}
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    {% if user.avatar %}
                                        <img src="{{ user.avatar }}" alt="{{ user.pseudo }}" class="w-10 h-10 rounded-full mr-3">
                                    {% else %}
                                        <div class="w-10 h-10 rounded-full flex items-center justify-center mr-3 text-sm" style="background-color: var(--color-primary-light); color: var(--color-primary);">
                                            {{ user.pseudo|slice(0, 1)|upper }}
                                        </div>
                                    {% endif %}
                                    <div>
                                        <div class="text-sm font-medium text-gray-900">{{ user.pseudo }}</div>
                                        {% if user.bio %}
                                            <div class="text-sm text-gray-500">{{ user.bio|slice(0, 50) }}
                                                {% if user.bio|length > 50 %}...
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-gray-900">{{ user.email }}</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <span class="badge-category-sm bg-accent-light text-accent">Admin</span>
                                {% else %}
                                    <span class="badge-category-sm text-primary bg-primary-light">Utilisateur</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                {% if user.isActive %}
                                    <span class="badge-category-sm bg-success-light text-success">Actif</span>
                                {% else %}
                                    <span class="badge-category-sm bg-error-light text-error">Inactif</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                {{ user.createdAt|date('d/m/Y') }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a href="{{ path('app_show_user', {id: user.id}) }}" class="link-nav mr-3">Voir</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="mt-6 border-t pt-6">
                <div class="pagination-wrapper">
                    {{ knp_pagination_render(pagination, null, {}, {
                        'search': search,
                        'filter': filter
                    }) }}
                </div>
            </div>
        {% else %}
            <p class="text-center text-gray-600 py-8">Aucun utilisateur trouvé</p>
        {% endif %}
    </div>

    {# Style personnalisé pour la pagination #}
    <style>
        .pagination-wrapper .pagination {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        .pagination-wrapper .pagination li {
            list-style: none;
        }
        .pagination-wrapper .pagination a,
        .pagination-wrapper .pagination span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 2.5rem;
            height: 2.5rem;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.2s;
        }
        .pagination-wrapper .pagination a {
            color: var(--color-text);
            background-color: white;
            text-decoration: none;
        }
        .pagination-wrapper .pagination a:hover {
            background-color: var(--color-primary);
            color: white;
            border-color: var(--color-primary);
        }
        .pagination-wrapper .pagination .active span {
            background-color: var(--color-primary);
            color: white;
            border-color: var(--color-primary);
        }
        .pagination-wrapper .pagination .disabled span {
            color: #9ca3af;
            cursor: not-allowed;
            background-color: #f9fafb;
        }
    </style>
{% endblock %}
