{% extends 'admin/base.html.twig' %}

{% block title %}Commentaires - Administration
{% endblock %}

{% block admin_content %}
    <div class="mb-8">
        <h1 class="text-4xl text-gray-900 mb-2">Gestion des commentaires</h1>
        <p class="text-gray-600">Gérez les commentaires de la plateforme</p>
    </div>

    <!-- Recherche -->
    <div class="card-padded mb-6">
        <form method="get" class="flex gap-4">
            <input type="text" name="search" value="{{ search }}" placeholder="Rechercher dans les commentaires..." class="form-input flex-1">
            <button type="submit" class="btn-primary">Rechercher</button>
            <a href="{{ path('app_admin_comment') }}" class="btn-secondary">Réinitialiser</a>
        </form>
    </div>

    <div class="card-padded bg-gray-50/50">
        {% if comments|length > 0 %}
            <div class="space-y-6">
                {% for comment in comments %}
                    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden transition-all hover:border-indigo-300">

                        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <div class="p-2 bg-indigo-100 text-indigo-700 rounded-lg">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 4v12l-4-2-4 2V4M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="font-bold text-gray-900 leading-tight">
                                        <a href="{{ path('app_tournament_show', {id: comment.tournament.id}) }}" class="hover:text-indigo-600 transition-colors" target="_blank">
                                            {{ comment.tournament.title }}
                                        </a>
                                    </h3>
                                    <div class="flex items-center gap-2 text-xs text-gray-500 mt-1">
                                        <span class="font-semibold text-indigo-600">@{{ comment.author.pseudo }}</span>
                                        <span>•</span>
                                        <span>{{ comment.createdAt|date('d/m/Y à H:i') }}</span>
                                    </div>
                                </div>
                            </div>

                            {% if comment.parentComment %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                Réponse
                            </span>
                            {% else %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                Message principal
                            </span>
                            {% endif %}
                        </div>

                        <div class="p-6">
                            {% if comment.parentComment %}
                                {# --- Affichage du contexte (Parent) --- #}
                                <div class="relative mb-6">
                                    <div class="absolute left-4 -top-2 bottom-0 w-0.5 bg-gray-200"></div>
                                    <div class="ml-8 p-4 bg-gray-50 border border-gray-200 rounded-lg italic text-sm text-gray-600">
                                        <div class="flex items-center gap-2 mb-1 not-italic">
                                            <span class="font-bold text-gray-700 text-xs">{{ comment.parentComment.author.pseudo }} a écrit :</span>
                                        </div>
                                        "{{ comment.parentComment.content|length > 150 ? comment.parentComment.content|slice(0, 150) ~ '...' : comment.parentComment.content }}"
                                    </div>
                                </div>

                                {# --- La réponse actuelle --- #}
                                <div class="flex gap-4">
                                    <div class="text-indigo-500 mt-1">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
                                        </svg>
                                    </div>
                                    <div class="flex-1 text-gray-800 text-base leading-relaxed whitespace-pre-line">
                                        {{ comment.content }}
                                    </div>
                                </div>
                            {% else %}
                                {# --- Affichage Commentaire Standard (Sans parent) --- #}
                                <div class="flex gap-4">
                                    <div class="text-gray-400 mt-1">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                                        </svg>
                                    </div>
                                    <div class="flex-1 text-gray-800 text-lg leading-relaxed whitespace-pre-line">
                                        {{ comment.content }}
                                    </div>
                                </div>
                            {% endif %}
                        </div>

                        <div class="px-6 py-3 bg-gray-50/30 border-t border-gray-100 flex justify-end">
                            <button
                                type="button"
                                class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50 rounded-md transition-colors"
                                onclick="openDeleteModal('{{ path('app_admin_comment_delete', {id: comment.id})|e('js') }}', '{{ csrf_token('delete_comment_' ~ comment.id)|e('js') }}')">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                Supprimer
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-12 bg-white rounded-xl border-2 border-dashed border-gray-200">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                <p class="mt-2 text-gray-600">Aucun commentaire ne correspond à votre recherche.</p>
            </div>
        {% endif %}
    </div>

    <!-- Modal de confirmation de suppression -->
    <div id="deleteModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-6 max-w-md w-full mx-4">
            <h3 class="text-xl font-bold mb-4">Confirmer la suppression</h3>
            <p class="text-gray-600 mb-6">Êtes-vous sûr de vouloir supprimer ce commentaire ? Cette action est irréversible. Si vous supprimer un commentaire parent tous ses enfants seront supprimé.</p>
            <div class="flex gap-3 justify-end">
                <button type="button" class="btn-secondary" onclick="closeDeleteModal()">Annuler</button>
                <form id="deleteForm" method="post" class="inline">
                    <input type="hidden" name="_token" id="deleteToken" value="">
                    <button type="submit" class="btn-danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        function openDeleteModal(actionUrl, csrfToken) {
            document.getElementById('deleteForm').action = actionUrl;
            document.getElementById('deleteToken').value = csrfToken;
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        document.getElementById('deleteModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeDeleteModal();
            }
        });
    </script>
{% endblock %}
