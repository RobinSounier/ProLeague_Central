{% extends 'admin/base.html.twig' %}

{% block title %}Administration - {{ team.name }}{% endblock %}

{% block admin_content %}
	<div class="mb-8">
		<a href="{{ path('app_admin_team_index') }}" class="link-nav mb-4 inline-block">
			← Retour à la liste
		</a>
		<div class="flex items-center gap-4 mb-2">
			<div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center">
				<span class="text-primary-dark font-bold text-xl">{{ team.name|slice(0, 2)|upper }}</span>
			</div>
			<div>
				<div class="flex items-center gap-3">
					<h1 class="text-4xl text-gray-900 font-bold" style="font-family: 'Outfit', sans-serif;">{{ team.name }}</h1>
					{% if team.isActive %}
						<span class="badge-success">Active</span>
					{% else %}
						<span class="badge-category-sm" style="background-color: var(--color-error-light); color: var(--color-error);">Inactive</span>
					{% endif %}
				</div>
				<p class="text-gray-600">
					{% if team.owner %}Par {{ team.owner.pseudo }} • {% endif %}
					{{ team.createdAt|date('d/m/Y à H:i') }}
					• ID #{{ team.id }}
				</p>
			</div>
		</div>
	</div>

	<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
		{# Informations principales #}
		<div class="lg:col-span-2 space-y-6">
			<div class="card-padded">
				<h2 class="text-2xl text-gray-900 mb-4" style="font-family: 'Outfit', sans-serif;">Informations</h2>
				<dl class="space-y-4">
					<div>
						<dt class="text-sm font-medium text-gray-500">Jeu</dt>
						<dd class="mt-1">
							<span class="badge-category-sm">{{ team.game.label ?? 'Non défini' }}</span>
						</dd>
					</div>
					<div>
						<dt class="text-sm font-medium text-gray-500">Propriétaire</dt>
						<dd class="mt-1 text-sm text-gray-900">
							{% if team.owner %}
								<div class="flex items-center gap-2">
									<div class="avatar-sm">
										<span>{{ team.owner.pseudo|slice(0, 2)|upper }}</span>
									</div>
									<span>{{ team.owner.pseudo ?? team.owner.email }}</span>
								</div>
							{% else %}
								<span class="text-gray-400">Aucun propriétaire</span>
							{% endif %}
						</dd>
					</div>
					<div>
						<dt class="text-sm font-medium text-gray-500">Statut</dt>
						<dd class="mt-1">
							{% if team.isActive %}
								<span class="badge-category-sm" style="background-color: var(--color-success-light); color: var(--color-success);">Active</span>
							{% else %}
								<span class="badge-category-sm" style="background-color: var(--color-error-light); color: var(--color-error);">Inactive</span>
							{% endif %}
						</dd>
					</div>
					<div>
						<dt class="text-sm font-medium text-gray-500">Date de création</dt>
						<dd class="mt-1 text-sm text-gray-900">{{ team.createdAt|date('d/m/Y à H:i') }}</dd>
					</div>
					<div>
						<dt class="text-sm font-medium text-gray-500">Dernière modification</dt>
						<dd class="mt-1 text-sm text-gray-900">
							{% if team.updatedAt %}
								{{ team.updatedAt|date('d/m/Y à H:i') }}
							{% else %}
								<span class="text-gray-400">Jamais modifiée</span>
							{% endif %}
						</dd>
					</div>
					<div>
						<dt class="text-sm font-medium text-gray-500">Statistiques</dt>
						<dd class="mt-1 text-sm text-gray-900">
							{{ team.users|length }} membre{{ team.users|length > 1 ? 's' : '' }}
							•
							{{ team.tournaments|length }} tournoi{{ team.tournaments|length > 1 ? 's' : '' }}
						</dd>
					</div>
					{% if team.description %}
						<div>
							<dt class="text-sm font-medium text-gray-500">Description</dt>
							<dd class="mt-1 text-sm text-gray-900 whitespace-pre-line">{{ team.description }}</dd>
						</div>
					{% endif %}
				</dl>
			</div>

			{# Membres #}
			<div class="card-padded">
				<div class="flex items-center justify-between mb-4">
					<h2 class="text-2xl text-gray-900" style="font-family: 'Outfit', sans-serif;">Membres</h2>
					<span class="badge-category-sm">{{ team.users|length }} membre{{ team.users|length > 1 ? 's' : '' }}</span>
				</div>
				{% if team.users|length > 0 %}
					<div class="space-y-3">
						{% for user in team.users %}
							<div class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 transition-colors">
								<div class="flex items-center gap-3">
									<div class="avatar-md bg-primary-light">
										<span class="text-primary-dark font-medium text-sm">{{ user.pseudo|slice(0, 2)|upper }}</span>
									</div>
									<div>
										<p class="font-medium text-gray-900">{{ user.pseudo }}</p>
										<p class="text-sm text-gray-500">{{ user.email }}</p>
									</div>
								</div>
								<div class="flex items-center gap-2">
									{% if team.owner and user.id == team.owner.id %}
										<span class="badge-category">
											<svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
												<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
											</svg>
											Owner
										</span>
									{% endif %}
								</div>
							</div>
						{% endfor %}
					</div>
				{% else %}
					<div class="text-center py-8">
						<svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
						</svg>
						<p class="text-gray-500">Aucun membre dans cette équipe</p>
					</div>
				{% endif %}
			</div>
		</div>

		{# Actions (sidebar) #}
		<div class="space-y-6">
			<div class="card-padded">
				<h2 class="text-2xl text-gray-900 mb-4" style="font-family: 'Outfit', sans-serif;">Actions</h2>
				<div class="space-y-3">
					<a href="{{ path('app_admin_team_edit', {id: team.id}) }}" class="btn-primary w-full">
						Modifier l'équipe
					</a>
					<form action="{{ path('app_admin_team_toggle', {id: team.id}) }}" method="post">
						<input type="hidden" name="_token" value="{{ csrf_token('toggle_team_' ~ team.id) }}">
						<button type="submit" class="btn-secondary w-full">
							{{ team.isActive ? 'Désactiver' : 'Activer' }} l'équipe
						</button>
					</form>
					<button type="button" onclick="openDeleteModal()" class="btn-danger w-full">
						Supprimer l'équipe
					</button>
				</div>
			</div>

			{# Tournois #}
			<div class="card-padded">
				<h2 class="text-2xl text-gray-900 mb-4" style="font-family: 'Outfit', sans-serif;">Tournois</h2>
				{% if team.tournaments|length > 0 %}
					<div class="space-y-3">
						{% for tournament in team.tournaments %}
							<div class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 transition-colors">
								<div>
									<p class="font-medium text-gray-900">{{ tournament.title }}</p>
									<p class="text-sm text-gray-500">{{ tournament.game.label ?? '' }}</p>
								</div>
								{% if tournament.isActive %}
									<span class="badge-category-sm" style="background-color: var(--color-success-light); color: var(--color-success);">Actif</span>
								{% else %}
									<span class="badge-category-sm">Terminé</span>
								{% endif %}
							</div>
						{% endfor %}
					</div>
				{% else %}
					<div class="text-center py-8">
						<svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
						</svg>
						<p class="text-gray-500 text-sm">Aucun tournoi</p>
					</div>
				{% endif %}
			</div>
		</div>
	</div>

	{# Modal de confirmation de suppression #}
	<div id="deleteModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50">
		<div class="bg-white rounded-xl p-6 max-w-md w-full mx-4 shadow-2xl">
			<div class="flex items-center justify-center w-12 h-12 bg-error-light rounded-full mx-auto mb-4">
				<svg class="w-6 h-6 text-error" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
				</svg>
			</div>
			<h3 class="text-xl font-bold text-center text-gray-900 mb-2">Confirmer la suppression</h3>
			<p class="text-gray-600 text-center mb-6">Êtes-vous sûr de vouloir supprimer l'équipe <strong>{{ team.name }}</strong> ? Cette action est irréversible.</p>
			<div class="flex gap-3 justify-center">
				<button type="button" class="btn-cancel" onclick="closeDeleteModal()">Annuler</button>
				<form action="{{ path('app_admin_team_delete', {id: team.id}) }}" method="post" class="inline">
					<input type="hidden" name="_token" value="{{ csrf_token('delete_team_' ~ team.id) }}">
					<button type="submit" class="btn-danger">Supprimer</button>
				</form>
			</div>
		</div>
	</div>

	<script>
		function openDeleteModal() {
			document.getElementById('deleteModal').classList.remove('hidden');
		}

		function closeDeleteModal() {
			document.getElementById('deleteModal').classList.add('hidden');
		}

		document.addEventListener('keydown', function(e) {
			if (e.key === 'Escape') closeDeleteModal();
		});

		document.getElementById('deleteModal').addEventListener('click', function(e) {
			if (e.target === this) closeDeleteModal();
		});
	</script>
{% endblock %}
