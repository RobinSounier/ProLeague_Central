{% extends 'admin/base.html.twig' %}

{% block title %}Administration - Créer une équipe{% endblock %}

{% block admin_content %}
	{# Bouton retour #}
	<div class="mb-6">
		<a href="{{ path('app_admin_team_index') }}" class="inline-flex items-center text-sm font-medium text-gray-600 hover:text-primary transition-colors">
			<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
			</svg>
			Retour à la liste
		</a>
	</div>

	{# En-tête #}
	<div class="text-center mb-12">
		<h1 class="text-4xl md:text-5xl text-gray-900 mb-4 font-bold" style="font-family: 'Outfit', sans-serif;">
			Créer une équipe
		</h1>
		<p class="text-xl text-gray-600 max-w-2xl mx-auto">
			Ajoutez une nouvelle équipe, assignez un propriétaire et configurez ses paramètres.
		</p>
	</div>

	{# Formulaire #}
	<div class="card-padded max-w-3xl mx-auto">
		{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

		{# Nom #}
		<div>
			{{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
			{{ form_widget(form.name, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Team Phoenix'}}) }}
			{{ form_errors(form.name) }}
		</div>

		{# Jeu & Propriétaire #}
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<div>
				{{ form_label(form.game, null, {'label_attr': {'class': 'form-label'}}) }}
				{{ form_widget(form.game, {'attr': {'class': 'form-select'}}) }}
				{{ form_errors(form.game) }}
				<p class="text-sm text-gray-500 mt-1">Le jeu sur lequel l'équipe évoluera.</p>
			</div>

			{% if form.owner is defined %}
				<div>
					{{ form_label(form.owner, null, {'label_attr': {'class': 'form-label'}}) }}
					{{ form_widget(form.owner, {'attr': {'class': 'form-select'}}) }}
					{{ form_errors(form.owner) }}
				</div>
			{% endif %}
		</div>

		{# Description #}
		<div>
			{{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
			{{ form_widget(form.description, {'attr': {'class': 'form-textarea', 'rows': '4', 'placeholder': 'Décrivez l\'équipe...'}}) }}
			{{ form_errors(form.description) }}
		</div>

		{# Statut #}
		{% if form.isActive is defined %}
			<div>
				<label class="form-label">Statut</label>
				<div class="flex items-center gap-6">
					<label class="inline-flex items-center cursor-pointer">
						{{ form_widget(form.isActive, {'attr': {'class': 'sr-only peer'}}) }}
						<div class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-orange-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
						<span class="ml-3 text-sm font-medium text-gray-700">Équipe active</span>
					</label>
				</div>
				{{ form_errors(form.isActive) }}
			</div>
		{% endif %}

		{# Membres #}
		{% if form.users is defined %}
			<div>
				{{ form_label(form.users, null, {'label_attr': {'class': 'form-label'}}) }}
				{{ form_widget(form.users, {'attr': {'class': 'form-select', 'size': '5'}}) }}
				<p class="text-sm text-gray-500 mt-1">Maintenez Ctrl (ou Cmd) pour sélectionner plusieurs membres.</p>
				{{ form_errors(form.users) }}
			</div>
		{% endif %}

		{# Champs restants #}
		{{ form_rest(form) }}

		{# Boutons d'action #}
		<div class="flex flex-col sm:flex-row gap-4 pt-6">
			<button type="submit" class="btn-primary-lg flex-1 flex items-center justify-center space-x-2">
				<svg class="icon" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M12 4.5v15m7.5-7.5h-15" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/></svg>
				<span>Créer l'équipe</span>
			</button>

			<a href="{{ path('app_admin_team_index') }}" class="btn-secondary flex-1 text-center justify-center">
				Annuler
			</a>
		</div>

		{{ form_end(form) }}
	</div>
{% endblock %}
