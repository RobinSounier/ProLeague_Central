{% extends 'admin/base.html.twig' %}

{% block title %}Administration - Équipes{% endblock %}

{% block admin_content %}
    {# En-tête #}
    <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-4xl text-gray-900 mb-2 font-bold" style="font-family: 'Outfit', sans-serif;">Gestion des Équipes</h1>
                <p class="text-gray-600">Administrez toutes les équipes de la plateforme</p>
            </div>
            <div class="mt-4 sm:mt-0">
                <a href="{{ path('app_admin_team_new') }}" class="btn-primary-lg">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Nouvelle équipe
                </a>
            </div>
        </div>
    </div>

    {# Statistiques rapides #}
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="card p-6">
            <div class="flex items-center">
                <div class="p-3 bg-primary-light rounded-lg">
                    <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-500">Total équipes</p>
                    <p class="text-2xl font-bold text-gray-900">{{ pagination.getTotalItemCount }}</p>
                </div>
            </div>
        </div>

        <div class="card p-6">
            <div class="flex items-center">
                <div class="p-3 bg-success-light rounded-lg">
                    <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-500">Actives</p>
                    <p class="text-2xl font-bold text-success">{{ teams|filter(t => t.isActive)|length }}</p>
                </div>
            </div>
        </div>

        <div class="card p-6">
            <div class="flex items-center">
                <div class="p-3 bg-error-light rounded-lg">
                    <svg class="w-6 h-6 text-error" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-500">Inactives</p>
                    <p class="text-2xl font-bold text-error">{{ teams|filter(t => not t.isActive)|length }}</p>
                </div>
            </div>
        </div>

        <div class="card p-6">
            <div class="flex items-center">
                <div class="p-3 bg-alert-light rounded-lg">
                    <svg class="w-6 h-6 text-alert" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-500">En tournoi</p>
                    <p class="text-2xl font-bold text-alert">{{ teams|filter(t => t.tournaments|length > 0)|length }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Compteur de résultats #}
    <div class="mb-4">
        <p class="text-sm text-gray-600">
            <strong>{{ pagination.getTotalItemCount }}</strong> équipe(s) au total
        </p>
    </div>

    {# Liste des équipes #}
    <div class="card-padded">
        {% if pagination.getTotalItemCount > 0 %}
            <div class="space-y-4">
                {% for team in pagination %}
                    <div class="border border-gray-200 rounded-lg p-6 hover:bg-gray-50 transition-colors {{ not team.isActive ? 'opacity-60' : '' }}">
                        <div class="flex items-start justify-between">
                            <div class="flex items-center gap-4 flex-1">
                                <div class="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center shrink-0">
                                    <span class="text-primary-dark font-bold">{{ team.name|slice(0, 2)|upper }}</span>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-3 mb-1">
                                        <h3 class="text-lg font-semibold text-gray-900">
                                            <a href="{{ path('app_admin_team_show', {id: team.id}) }}" class="hover:text-primary transition-colors">
                                                {{ team.name }}
                                            </a>
                                        </h3>
                                        <span class="text-xs text-gray-400">#{{ team.id }}</span>
                                        {% if team.isActive %}
                                            <span class="badge-success">Active</span>
                                        {% else %}
                                            <span class="badge-category-sm" style="background-color: var(--color-error-light); color: var(--color-error);">Inactive</span>
                                        {% endif %}
                                    </div>
                                    {% if team.description %}
                                        <p class="text-gray-600 text-sm mb-2 truncate max-w-2xl">{{ team.description|slice(0, 120) }}{% if team.description|length > 120 %}...{% endif %}</p>
                                    {% endif %}
                                    <div class="flex items-center gap-4 text-sm text-gray-500">
                                        <span class="badge-category-sm">{{ team.game.label ?? 'Non défini' }}</span>
                                        {% if team.owner %}
                                            <span>Par {{ team.owner.pseudo ?? team.owner.email }}</span>
                                        {% endif %}
                                        <span>{{ team.createdAt|date('d/m/Y') }}</span>
                                        <span>{{ team.users|length }} membre{{ team.users|length > 1 ? 's' : '' }}</span>
                                        <span>{{ team.tournaments|length }} tournoi{{ team.tournaments|length > 1 ? 's' : '' }}</span>
                                    </div>
                                </div>
                            </div>
                            <div class="ml-4 flex items-center gap-2 shrink-0">
                                <a href="{{ path('app_admin_team_show', {id: team.id}) }}" class="btn-secondary text-sm">Voir</a>
                                <a href="{{ path('app_admin_team_edit', {id: team.id}) }}" class="btn-secondary text-sm">Modifier</a>
                                <form action="{{ path('app_admin_team_toggle', {id: team.id}) }}" method="post" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle_team_' ~ team.id) }}">
                                    <button type="submit" class="btn-secondary text-sm">
                                        {{ team.isActive ? 'Désactiver' : 'Activer' }}
                                    </button>
                                </form>
                                <button type="button"
                                        data-id="{{ team.id }}"
                                        data-name="{{ team.name|e('html_attr') }}"
                                        data-token="{{ csrf_token('delete_team_' ~ team.id) }}"
                                        onclick="openDeleteModal(this)"
                                        class="btn-danger text-sm">
                                    Supprimer
                                </button>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# Pagination #}
            <div class="mt-6 border-t pt-6">
                <div class="pagination-wrapper">
                    {{ knp_pagination_render(pagination) }}
                </div>
            </div>
        {% else %}
            <div class="text-center py-12">
                <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                <p class="text-gray-500 text-lg mb-2">Aucune équipe trouvée</p>
                <a href="{{ path('app_admin_team_new') }}" class="btn-primary">Créer une équipe</a>
            </div>
        {% endif %}
    </div>

    {# Modal de confirmation de suppression #}
    <div id="deleteModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 max-w-md w-full mx-4 shadow-2xl">
            <div class="flex items-center justify-center w-12 h-12 bg-error-light rounded-full mx-auto mb-4">
                <svg class="w-6 h-6 text-error" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
            </div>
            <h3 class="text-xl font-bold text-center text-gray-900 mb-2">Confirmer la suppression</h3>
            <p class="text-gray-600 text-center mb-6">Êtes-vous sûr de vouloir supprimer l'équipe <strong id="teamNameToDelete"></strong> ? Cette action est irréversible.</p>
            <div class="flex gap-3 justify-center">
                <button type="button" class="btn-cancel" onclick="closeDeleteModal()">Annuler</button>
                <form id="deleteForm" action="" method="post" class="inline">
                    <input type="hidden" name="_token" id="deleteToken" value="">
                    <button type="submit" class="btn-danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

    {# Style personnalisé pour la pagination #}
    <style>
        .pagination-wrapper .pagination {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        .pagination-wrapper .pagination li {
            list-style: none;
        }
        .pagination-wrapper .pagination a,
        .pagination-wrapper .pagination span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 2.5rem;
            height: 2.5rem;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.2s;
        }
        .pagination-wrapper .pagination a {
            color: var(--color-text);
            background-color: white;
            text-decoration: none;
        }
        .pagination-wrapper .pagination a:hover {
            background-color: var(--color-primary);
            color: white;
            border-color: var(--color-primary);
        }
        .pagination-wrapper .pagination .active span {
            background-color: var(--color-primary);
            color: white;
            border-color: var(--color-primary);
        }
        .pagination-wrapper .pagination .disabled span {
            color: #9ca3af;
            cursor: not-allowed;
            background-color: #f9fafb;
        }
    </style>

    <script>
        function openDeleteModal(button) {
            const id = button.dataset.id;
            const name = button.dataset.name;
            const token = button.dataset.token;

            document.getElementById('teamNameToDelete').textContent = name;
            document.getElementById('deleteForm').action = '/admin/team/' + id;
            document.getElementById('deleteToken').value = token;
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeDeleteModal();
        });

        document.getElementById('deleteModal').addEventListener('click', function(e) {
            if (e.target === this) closeDeleteModal();
        });
    </script>
{% endblock %}
