{% extends 'base.html.twig' %}

{% block title %}Modifier une équipe - ProLeague Central
{% endblock %}

{% block body %}
	<section class="section">
		<div
			class="container-medium">

			{# En-tête #}
			<div class="text-center mb-6">
				<h1 class="text-4xl md:text-5xl text-gray-900 mb-4 font-bold" style="font-family: 'Outfit', sans-serif;">
					Modifier votre Team
				</h1>
				<p class="text-xl text-gray-600 max-w-2xl mx-auto">
					Continuer à rassembler vos joueurs, re-définissez votre identité et continuez à vous préparer à la compétition.
				</p>
			</div>

			{# Formulaire #}
			<div class="card-padded max-w-3xl mx-auto">
				{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

				{# Champ Nom #}
				<div>
					{{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
					{{ form_widget(form.name, {'attr': {'class': 'form-input'}}) }}
					{{ form_errors(form.name) }}
				</div>

				{# --- CHAMP JEU --- #}
				<div>
					{{ form_label(form.game, null, {'label_attr': {'class': 'form-label'}}) }}
					{{ form_widget(form.game, {'attr': {'class': 'form-input w-full cursor-pointer'}}) }}
					{{ form_errors(form.game) }}
					<p class="text-sm text-gray-500 mt-1">Le jeu sur lequel votre équipe évoluera principalement.</p>
				</div>
				{# ------------------------- #}

				{# Champ Description #}
				<div>
					{{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
					{{ form_widget(form.description, {'attr': {'class': 'form-textarea'}}) }}
					{{ form_errors(form.description) }}
				</div>

				{# Boutons d'action #}
				<div class="flex flex-col sm:flex-row gap-4 pt-6">
					<button type="submit" class="btn-primary-lg flex-1 flex items-center justify-center space-x-2">
						<svg class="icon" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewbox="0 0 24 24"><path fill="currentColor" d="M3 21v-4.25L16.2 3.575q.3-.275.663-.425t.762-.15t.775.15t.65.45L20.425 5q.3.275.438.65T21 6.4q0 .4-.137.763t-.438.662L7.25 21zM17.6 7.8L19 6.4L17.6 5l-1.4 1.4z"/></svg>
						<span>Modifier votre équipe</span>
					</button>

					<a href="{{ path('app_team_index') }}" class="btn-secondary flex-1 text-center justify-center">
						Annuler
					</a>
				</div>

				{{ form_end(form) }}
			</div>
		</div>
	</section>
{% endblock %}
