{% extends 'base.html.twig' %}

{% block title %}Team index{% endblock %}

{% block body %}
    <div class="max-h-screen bg-bg-main py-8">
        <div class="container-main">
            {% include "partials/_messages.html.twig" %}
            <!-- En tête -->
            <div class="mb-8">
                <h1 class="text-4xl text-gray-900 mb-2">Toute les équipes</h1>
                <p class="text-gray-600">Découvrez et rejoinez l'équipe qui vous conviendra.</p>
            </div>
            <a href="{{ path('app_team_new') }}" class="btn-primary">Crée mon équipe</a>
        </div>
        <div class="card-sm p-6 mb-8">
            <form class="flex flex-col md:flex-row gap-4" action="{{ path('app_challenge_index') }}" method="get">
                <!-- filtre de catégorie -->
                <div class="flex-1">
                    <label class="form-label" for="games">
                        Sélectionner un jeu
                    </label>
                    <select name="game" id="games" class="form-select" onchange="this.form.submit()">
                        <option value="0" {{ selectGame == 0 ? 'selected' : '' }}>Toutes les catégories</option>
                        {% for category in caterogies %}
                            <option
                                value="{{ game.id }}" {{ selectCGame == game.id ? 'selcted' : '' }}> {{ game.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <!-- button de renitialisation -->
                {% if selectCategory != 0%}
                    <div class="flex items-end">
                        <a href="{{ path('app_challenge_index') }}" class="px-4 py-2 transition-colors link-nav">
                            Rénitialiser
                        </a>
                    </div>
                {% endif %}
            </form>

        </div>


    </div>
{% endblock %}
