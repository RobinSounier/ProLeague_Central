{% extends 'base.html.twig' %}

{% block title %}
    {{ tournament.title }} - CreativeHub
{% endblock %}

{% block body %}
    <div class="min-h-screen bg-main py-8">
        <div class="container-medium">
            {% include "partials/_messages.html.twig" %}

            {# Bouton retour #}
            <a class="link-nav inline-flex items-center mb-10" href="{{ path('app_tournament_index') }}">
                <svg class="icon-sm mr-2" fill="none" stroke="currentColor" viewbox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
                </svg>
                <span>Retour aux tournois</span>
            </a>

            {# Carte principale du tournoi #}
            <div class="card overflow-hidden mb-10">
                {# Image #}
                {% if tournament.medias|length > 0 %}
                    <div class="p-4">
                        <div class="grid grid-cols-2 gap-4">
                            {% for media in tournament.medias %}
                                <div class="relative group">
                                    <img src="{{ media.path }}" alt="Média {{ loop.index }}"
                                         class="w-full h-48 object-cover rounded-lg border border-gray-200">
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% else %}
                    <div class="w-full h-96 gradient-placeholder flex items-center justify-center">
                        <svg class="w-16 h-16" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em"
                             viewBox="0 0 24 24">
                            <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                               stroke-width="2">
                                <path
                                    d="M15 8h.01M3 6a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v12a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3z"/>
                                <path d="m3 16l5-5c.928-.893 2.072-.893 3 0l5 5"/>
                                <path d="m14 14l1-1c.928-.893 2.072-.893 3 0l3 3"/>
                            </g>
                        </svg>

                    </div>
                {% endif %}

                <div class="p-8">
                    {# En-tête #}
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex-1">
                            <div class="flex items-center justify-between mb-4">
                                <span class="badge-category">
                                    {{ tournament.game.label }}
                                </span>
                                {% if app.user %}
                                    {% if app.user == tournament.owner or is_granted('ROLE_ADMIN') %}
                                        <div class="flex gap-2">
                                            <a class="btn-secondary flex items-center space-x-2"
                                               href="{{ path('app_tournament_edit', {id: tournament.id}) }}">
                                                <svg class="icon-with-text" fill="none" stroke="currentColor"
                                                     viewbox="0 0 24 24" stroke-width="2">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                                </svg>
                                                <span>Modifier</span>
                                            </a>
                                            <button type="button" class="btn-danger flex items-center space-x-2" onclick="openDeleteModal()">
                                                <svg class="icon-with-text" fill="none" stroke="currentColor"
                                                     viewbox="0 0 24 24" stroke-width="2">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                                </svg>
                                                <span>Supprimer</span>
                                            </button>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </div>
                            <h1 class="text-4xl font-bold text-gray-900 mb-4">{{ tournament.title }}</h1>
                            <div class="flex items-center text-gray-600 mb-4">
                                <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor"
                                     viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                                <p class="text-sm">Créé le {{ tournament.createdAt|date('d/m/Y à H:i') }}</p>
                            </div>
                        </div>

                        <div class="vote-container">
                            {% if app.user %}
                                <button
                                    class="vote-button {{ hasVoted ? 'voted' : '' }}"
                                    id="vote-button"
                                    data-tournament-id="{{ tournament.id }}"
                                    data-has-voted="{{ hasVoted ? 'true' : 'false' }}"
                                    aria-label="Like">

                                    <svg
                                        class="icon-like"
                                        fill="{{ hasVoted ? 'currentColor' : 'none' }}"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        stroke-width="2">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                                    </svg>

                                </button>
                            {% else %}
                                {# Style simplifié pour les non-connectés #}
                                <div class="text-center opacity-50">
                                    <span class="block text-2xl font-bold text-gray-400">{{ voteCount }}</span>
                                    <svg class="w-6 h-6 mx-auto text-gray-300" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path
                                            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                    </svg>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="prose max-w-none mb-10">
                        <p class="text-gray-700 leading-relaxed whitespace-pre-line">{{ tournament.description }}</p>
                    </div>


                    {# 3. Affichage conditionnel : le lien ET (l'appartenance à l'équipe OU admin) #}
                    {% if tournament.link and (isRegistered or is_granted('ROLE_ADMIN')) %}
                        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-10">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                                    </svg>
                                    <p class="font-medium text-blue-900">Lien du tournoi (Réservé aux participants)</p>
                                </div>
                                <a href="{{ tournament.link }}" target="_blank" rel="noopener noreferrer"
                                   class="btn-secondary-transparent flex items-center space-x-2 text-accent">
                                    <span>Accéder au salon</span>
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    {% else %}
                        <div class="bg-gray-50 border border-red-200 rounded-lg p-4 mb-10">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 mr-2 text-gray-600" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                                    </svg>
                                    <p class="font-medium text-gray-600">Inscrivez vous pour accédez au lien</p>
                                </div>
                            </div>
                        </div>
                    {% endif %}

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
                        {% if tournament.deadlineJoin %}
                            <div class="alert-warning">
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor"
                                         viewbox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                                    </svg>
                                    <div>
                                        <p class="font-medium text-blue-900">Inscription jusqu'au</p>
                                        <p class="text-sm text-blue-700">{{ tournament.deadlineJoin|date('d/m/Y à H:i') }}</p>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                        {% if tournament.deadline %}
                            <div class="alert-warning">
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 mr-2 text-accent" fill="none" stroke="currentColor"
                                         viewbox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <div>
                                        <p class="font-medium text-accent">Fin du tournoi</p>
                                        <p class="text-sm text-accent">{{ tournament.deadline|date('d/m/Y à H:i') }}</p>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    </div>

                    <div class="flex items-center space-x-6 pt-6 border-t border-gray-200">
                        <div class="vote-stats">
                            <svg fill="none" class="icon" stroke="currentColor" viewbox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                            </svg>
                            <span id="stats-vote-count">{{ voteCount }} vote{{ voteCount > 1 ? 's' : '' }}</span>
                        </div>
                        <div class="vote-stats">
                            <svg fill="none" class="icon" stroke="currentColor" viewbox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                            </svg>
                            <span>{{ tournament.teams|length }} équipe{{ tournament.teams|length > 1 ? 's' : '' }}</span>
                        </div>
                        <div class="vote-stats">
                            <svg fill="none" class="icon" stroke="currentColor" viewbox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                            </svg>
                            <span>{{ tournament.comments|length }} commentaire{{ tournament.comments|length > 1 ? 's' : '' }}</span>
                        </div>
                    </div>
                    <div class="card-padded shadow-sm border border-gray-100 rounded-xl bg-white overflow-hidden mt-10">
                        <div class="p-5 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                            <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                                <span class="w-2 h-6 bg-primary rounded-full"></span>
                                Équipes inscrites
                            </h2>
                            <span
                                class="bg-primary/10 text-primary text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
                                {{ allTeamsRegistred|length }} Équipes
                            </span>
                        </div>
                        <div class="p-2 overflow-y-auto">
                            {% if allTeamsRegistred and allTeamsRegistred|length > 0 %}
                                <div class="grid gap-1">
                                    {% for team in allTeamsRegistred %}
                                        <div
                                            class="group flex items-center p-3 rounded-lg hover:bg-indigo-50/50 transition-all duration-200 cursor-default">
                                            <div
                                                class="w-11 h-11 rounded-full bg-primary flex items-center justify-center mr-4 text-base shadow-sm group-hover:scale-105 transition-transform">
                                                {{ team.name|first|upper }}
                                            </div>
                                            <div class="flex flex-col">
                                                <span
                                                    class="text-gray-700 font-semibold group-hover:text-primary transition-colors">
                                                    {{ team.name }}
                                                </span>
                                                <span class="text-xs text-gray-400">Inscrit au tournoi</span>
                                            </div>
                                            <div class="ml-auto opacity-0 group-hover:opacity-100 transition-opacity">
                                                <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded">Actif</span>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="py-12 text-center">
                                    <div
                                        class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 text-gray-400 mb-4">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none"
                                             viewbox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                        </svg>
                                    </div>
                                    <p class="text-gray-500 font-medium">Aucune équipe inscrite pour le moment.</p>
                                    <p class="text-sm text-gray-400">Soyez la première équipe à rejoindre !</p>
                                </div>
                            {% endif %}
                        </div>

                        <div class="px-5 py-4 bg-gray-50/30 border-t border-gray-50 text-right">
                            <p class="text-sm text-gray-500 italic">
                                Total : <strong class="text-gray-700">{{ allTeamsRegistred|length }}</strong>
                                équipe{{ allTeamsRegistred|length > 1 ? 's' : '' }}
                            </p>
                        </div>
                        <div class="card-padded border rounded-lg p-4 bg-white shadow-sm mt-10">
                            <h3 class="font-bold mb-3 text-gray-800">Participer au tournoi</h3>

                            {% if app.user and app.user.ownerTeams|length > 0 %}
                                <form action="{{ path('app_tournament_register_team', {'id': tournament.id}) }}"
                                      method="POST" class="flex flex-col gap-3">

                                    {% if app.user.ownerTeams|length > 1 %}
                                        {# Si plusieurs équipes : on laisse le choix #}
                                        <label for="team_select" class="text-sm text-gray-600">Choisissez votre équipe
                                            :</label>
                                        <select name="team_id" id="team_select"
                                                class="border rounded px-3 py-2 bg-gray-50 focus:ring-2 focus:ring-primary outline-none">
                                            {% for team in app.user.ownerTeams %}
                                                {% if not tournament.teams.contains(team) %}
                                                    <option value="{{ team.id }}">{{ team.name }}</option>
                                                {% endif %}
                                            {% endfor %}
                                        </select>
                                    {% else %}
                                        {# Si une seule équipe : on l'utilise directement #}
                                        {% set singleTeam = app.user.ownerTeams|first %}
                                        <input type="hidden" name="team_id" value="{{ singleTeam.id }}">
                                        <p class="text-sm text-gray-700">Inscrire votre équipe :
                                            <strong>{{ singleTeam.name }}</strong></p>
                                    {% endif %}

                                    <button type="submit"
                                            class="bg-primary hover:bg-indigo-700 text-white font-bold py-2 px-6 rounded-lg transition-all shadow-md">
                                        Confirmer l'inscription
                                    </button>
                                </form>
                            {% elseif app.user %}
                                <div class="text-center p-4 bg-yellow-50 rounded border border-yellow-100">
                                    <p class="text-yellow-700 text-sm">Vous n'avez pas encore d'équipe dont vous êtes le
                                        chef.</p>
                                    <a href="{{ path('app_team_new') }}"
                                       class="text-primary font-bold text-sm underline mt-2 inline-block">Créer une
                                        équipe</a>
                                </div>
                            {% else %}
                                <a href="{{ path('app_login') }}"
                                   class="block text-center bg-gray-100 py-2 rounded text-gray-600">Connectez-vous pour
                                    inscrire votre équipe</a>
                            {% endif %}
                        </div>
                    </div>

                </div>
            </div>

            {# Section commentaires #}
            {% if app.user %}
                <div class="mb-10">
                    {{ form_start(commentForm, {
                        'action': path('app_comment_create', {id: tournament.id}),
                        'method': 'POST',
                        'attr': {
                            'class': 'space-y-4'
                        }
                    }) }}
                    <!-- Gestion du message d'erreur et affichage de l'input -->
                    <div>
                        {{ form_widget(commentForm.content) }}
                        {% if commentForm.content.vars.errors|length > 0 %}
                            <div class="mt-2 text-sm text-red-600">
                                {{ form_errors(commentForm.content) }}
                            </div>
                        {% endif %}
                    </div>
                    {{ form_rest(commentForm) }}
                    <button type="submit" class="btn-primary-lg flex items-center space-x-2">
                        <svg class="icon-with-text" fill="none" stroke="currentColor" viewbox="0 0 24 24"
                             stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                        </svg>
                        <span>Publier le commentaire</span>
                    </button>
                    {{ form_end(commentForm) }}
                </div>
            {% else %}
                <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 mb-10 text-center">
                    <p class="text-gray-600 mb-4">Connectez-vous pour laisser un commentaire</p>
                    <a href="{{ path('app_login') }}" class="btn-primary-lg inline-flex items-center space-x-2">
                        <svg class="icon-with-text" fill="none" stroke="currentColor" viewbox="0 0 24 24"
                             stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
                        </svg>
                        <span>Se connecter</span>
                    </a>
                </div>
            {% endif %}
            <!-- Liste des commentaires -->
            <div class="space-y-6">
                {% if comments|length > 0 %}
                    {% for comment in comments %}
                        {% include "partials/_comment.html.twig" with {
                            'comment': comment,
                            'level': 0,
                            'tournament': tournament
                        } %}
                    {% endfor %}
                {% else %}
                    <div class="text-center py-12 text-gray-500">
                        <svg class="w-16 h-16 mx-auto mb-4 text-gray-400" fill="none" stroke="currentColor"
                             viewbox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                        </svg>
                        <p>Aucun commentaire pour le moment. Soyez le premier à commenter !</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Modal de confirmation de suppression -->
    <div id="deleteModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-6 max-w-md w-full mx-4">
            <h3 class="text-xl font-bold mb-4">Confirmer la suppression</h3>
            <p class="text-gray-600 mb-6">Êtes-vous sûr de vouloir supprimer ce tournoi ? Cette action est irréversible.</p>
            <div class="flex gap-3 justify-end">
                <button type="button" class="btn-secondary" onclick="closeDeleteModal()">Annuler</button>
                <form action="{{ path('app_tournament_delete', {id: tournament.id}) }}" method="post" class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_tournament_' ~ tournament.id) }}">
                    <button type="submit" class="btn-danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

    {% block javascript %}
    <script>
        function openDeleteModal() {
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        document.getElementById('deleteModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeDeleteModal();
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
        const voteButton = document.getElementById('vote-button');
        if (!voteButton) return;

        voteButton.addEventListener('click', function() {
        const button = this;
        const tournamentId = button.dataset.tournamentId;
        const hasVoted = button.dataset.hasVoted === 'true';

        // URLs générées dynamiquement selon tes nouvelles routes
        const urlAdd = "{{ path('app_tournament_vote_add', {id: tournament.id}) }}";
                const urlDelete = "{{ path('app_tournament_vote_delete', {id: tournament.id}) }}";

                const url = hasVoted ? urlDelete : urlAdd;
                const method = hasVoted ? 'DELETE' : 'POST';

                button.disabled = true;

                fetch(url, {
                    method: method,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        throw new Error(data.message);
                    }

                    // Mise à jour de l'état local du bouton
                    const newHasVoted = !hasVoted;
                    button.dataset.hasVoted = newHasVoted.toString();

                    // Mise à jour visuelle (Classes et Textes)
                    button.classList.toggle('voted', newHasVoted);


                    // Mise à jour des compteurs (Bouton + Barre de stats)
                    const countElements = [
                        document.getElementById('vote-count'),
                        document.getElementById('stats-vote-count')
                    ];

                    countElements.forEach(el => {
                        if (el) {
                            if (el.id === 'stats-vote-count') {
                                el.textContent = `${data.voteCount} vote${data.voteCount > 1 ? 's' : ''}`;
                            } else {
                                el.textContent = data.voteCount;
                            }
                        }
                    });
                })
                .catch(error => {
                    alert(error.message || "Une erreur est survenue");
                })
                .finally(() => {
                    button.disabled = false;
                });
            });
        });
    </script>
    {% endblock %}
{% endblock %}
