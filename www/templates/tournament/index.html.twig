{% extends 'base.html.twig' %}

{% block title %}Tournois - ProLeague Central{% endblock %}

{% block body %}
    <div class="min-h-screen bg-main py-8">
        <div class="container-medium">
            {% include "partials/_messages.html.twig" %}

            {# En-tête avec titre et bouton créer #}
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h1 class="text-4xl font-bold text-gray-900 mb-2">Tournois</h1>
                    <p class="text-gray-600">Découvrez et participez aux tournois en cours</p>
                </div>
                {% if app.user %}
                    <a href="{{ path('app_tournament_new') }}" class="btn-primary-lg flex items-center space-x-2">
                        <svg class="icon-with-text" fill="none" stroke="currentColor" viewbox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
                        </svg>
                        <span>Créer un tournoi</span>
                    </a>
                {% endif %}
            </div>

            {# Filtres #}
            <div class="card mb-6">
                <form class="flex flex-wrap items-center gap-4 p-6" action="{{ path('app_tournament_index') }}" method="get">
                    {# Filtre par jeu #}
                    <div class="flex-1 min-w-[200px]">
                        <label for="game" class="block text-sm font-medium text-gray-700 mb-2">Filtrer par jeu</label>
                        <select id="game" name="game" class="form-select" onchange="this.form.submit()">
                            <option value="0" {{ selectedGame == 0 ? 'selected' : '' }}>Tous les jeux</option>
                            {% for game in games %}
                                <option value="{{ game.id }}" {{ selectedGame == game.id ? 'selected' : '' }}>
                                    {{ game.label }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Filtre de tri #}
                    <div class="flex-1 min-w-[200px]">
                        <label for="sort" class="block text-sm font-medium text-gray-700 mb-2">Trier par</label>
                        <select id="sort" name="sort" class="form-select" onchange="this.form.submit()">
                            <option value="recent" {{ selectedSortBy == 'recent' ? 'selected' : '' }}>Plus récents</option>
                            <option value="popular" {{ selectedSortBy == 'popular' ? 'selected' : '' }}>Plus populaires</option>
                            <option value="oldest" {{ selectedSortBy == 'oldest' ? 'selected' : '' }}>Plus anciens</option>
                        </select>
                    </div>

                    {# Bouton réinitialiser #}
                    {% if selectedGame != 0 or selectedSortBy != 'recent' %}
                        <div class="flex items-end">
                            <a href="{{ path('app_tournament_index') }}" class="link-nav px-4 py-2">
                                Réinitialiser
                            </a>
                        </div>
                    {% endif %}
                </form>
            </div>
            {# Liste des tournois #}
            <div class="my-6">
                {% if tournaments|length > 0 %}
                    {% for tournament in tournaments %}
                        <div class="card group hover:shadow-lg transition-shadow duration-300 my-6">
                            {# Image ou placeholder #}
                            {% if tournament.medias|length > 0 %}
                                <div class="relative overflow-hidden rounded-t-lg">
                                    <img src="{{ tournament.medias[0].path }}"
                                         alt="{{ tournament.title }}"
                                         class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300">
                                </div>
                            {% else %}
                                <div class="w-full h-48 gradient-placeholder rounded-t-lg flex items-center justify-center">
                                    <svg class="w-16 h-16" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M15 8h.01M3 6a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v12a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3z"/><path d="m3 16l5-5c.928-.893 2.072-.893 3 0l5 5"/><path d="m14 14l1-1c.928-.893 2.072-.893 3 0l3 3"/></g></svg>
                                </div>
                            {% endif %}

                            <div class="p-6">
                                {# Badge du jeu #}
                                <span class="badge-category mb-3">
                                    {{ tournament.game.label }}
                                </span>

                                {# Titre #}
                                <h3 class="text-xl font-bold text-gray-900 mb-2 line-clamp-2">
                                    {{ tournament.title }}
                                </h3>

                                {# Description #}
                                <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                                    {{ tournament.description }}
                                </p>

                                {# Deadlines #}
                                <div class="space-y-2 mb-4">
                                    {% if tournament.deadlineJoin %}
                                        <div class="flex items-center text-sm text-gray-600">
                                            <svg class="w-4 h-4 mr-2 text-blue-500" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                      d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                                            </svg>
                                            <span>Inscription: {{ tournament.deadlineJoin|date('d/m/Y') }}</span>
                                        </div>
                                    {% endif %}
                                    {% if tournament.deadline %}
                                        <div class="flex items-center text-sm text-gray-600">
                                            <svg class="w-4 h-4 mr-2 text-alert" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                            <span>Fin: {{ tournament.deadline|date('d/m/Y') }}</span>
                                        </div>
                                    {% endif %}
                                </div>

                                {# Statistiques #}
                                <div class="flex items-center justify-between pt-4 mt-4 border-t border-gray-100">
                                    <div class="flex items-center space-x-4">

                                        <div class="flex items-center text-sm font-medium text-gray-600">
                                            <svg class="w-5 h-5 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                            </svg>
                                            <span>{{ tournament.teams|length }} équipe{{ tournament.teams|length > 1 ? 's' : '' }}</span>
                                        </div>

                                        <div class="flex items-center text-sm font-medium text-pink-600 bg-pink-50 px-2 py-1 rounded-full">
                                            <svg class="w-4 h-4 mr-1 text-pink-500" fill="currentColor" viewBox="0 0 24 24">
                                                <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                            </svg>
                                            <span>{{ tournament.votes|length }}</span>
                                        </div>

                                    </div>
                                </div>

                                {# Boutons d'action #}
                                <div class="mt-4 flex gap-2">
                                    <a href="{{ path('app_tournament_show', {'id': tournament.id}) }}"
                                       class="btn-primary flex-1 text-center">
                                        Voir les détails
                                    </a>
                                    {% if app.user and (is_granted('ROLE_ADMIN') or tournament.owner == app.user) %}
                                        <a href="{{ path('app_tournament_edit', {'id': tournament.id}) }}"
                                           class="btn-secondary">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                            </svg>
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="col-span-full text-center py-12">
                        <svg class="w-24 h-24 mx-auto mb-4 text-gray-400" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
                        </svg>
                        <h3 class="text-xl font-medium text-gray-900 mb-2">Aucun tournoi disponible</h3>
                        <p class="text-gray-600 mb-4">Soyez le premier à créer un tournoi !</p>
                        {% if app.user %}
                            <a href="{{ path('app_tournament_new') }}" class="btn-primary-lg inline-flex items-center space-x-2">
                                <svg class="icon-with-text" fill="none" stroke="currentColor" viewbox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
                                </svg>
                                <span>Créer un tournoi</span>
                            </a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
